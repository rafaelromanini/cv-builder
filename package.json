{
  "name": "cv-builder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A modern, drag-and-drop CV builder built with React, TypeScript, Vite and Tailwind. Multiple templates, PDF export, JSON import/export and a bilingual (PT/EN) UI.",
  "author": "Rafael Romanini <rafaromaninideoliveira@gmail.com>",
  "license": "MIT",
  "keywords": [
    "cv",
    "resume",
    "react",
    "typescript",
    "vite",
    "tailwindcss",
    "dnd-kit"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
